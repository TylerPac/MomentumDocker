{
  "expo": {
    "name": "Momentum",
    "slug": "momentum",
    "version": "0.1.0",
    "scheme": "momentum",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.tylerpac.momentum"
    },
    "android": {
      "package": "dev.tylerpac.momentum",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f19"
      }
    },
    "plugins": ["expo-router"],
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:8080"
    }
  }
}
